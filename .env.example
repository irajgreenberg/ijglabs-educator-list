PORT=3220
PUBLIC_URL=https://educator-list.ijglabs.ai
# Leave INTERNAL_TOKEN blank to disable the CSV export endpoint.
INTERNAL_TOKEN=
# Required: any random hex string. The server refuses to start without it.
