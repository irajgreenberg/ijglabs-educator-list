PORT=3220
PUBLIC_URL=https://educator-list.ijglabs.ai
# Required: any random hex string. The server refuses to start without it.
IP_HASH_PEPPER=
# SMTP block — submission notifications. If any are missing the server skips notifications.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_TO=
# Admin block — if any are missing or weak, /admin returns 503.
# ADMIN_EMAILS: comma-separated allowlist of who can sign in.
# ADMIN_PASSWORD: shared password; must be at least 8 chars.
# SESSION_SECRET: any random hex string at least 32 chars long.
ADMIN_EMAILS=
ADMIN_PASSWORD=
SESSION_SECRET=
